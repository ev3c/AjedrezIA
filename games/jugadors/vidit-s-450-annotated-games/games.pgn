1. c4 {[%emt 0:00:06]} e5 {[%emt 0:00:28]} 2. g3 {[%emt 0:00:09]} Nf6 {[%emt 0:00:32]} 3. Bg2 {[%emt 0:00:06]} d5 {[%emt 0:00:09]} 4. cxd5 {[%emt 0:00:05]} Nxd5 {[%emt 0:00:08]} 5. Nf3 {[%emt 0:00:04]} Nc6 {[%emt 0:00:10]} 6. O-O {[%emt 0:00:08]} Nb6 {[%emt 0:00:16]} 7. d3 {[%emt 0:00:45]} Be7 {[%emt 0:01:57]} 8. a3 {[%emt 0:05:09]} O-O {[%emt 0:08:39]} 9. Nbd2 {[%emt 0:00:25]} a5 {[%emt 0:00:22]} 10. b3 {[%emt 0:00:15]} Be6 {[%emt 0:00:21]} 11. Bb2 {[%emt 0:00:47]} f6 {[%emt 0:00:12]} 12. Qc2 {[%emt 0:01:54]} Qd7 {[%emt 0:00:30]} 13. Nc4 {[%emt 0:08:38]} Rfd8 {[%emt 0:05:24]} (13... Rad8 14. Rfd1 Bf5 15. Bc3 Nxc4 16. bxc4 b6 17. Qb2 Bc5 18. Nd2 Kh8 19. Ne4 Bd4 20. Bxd4 Nxd4 21. e3 Ne6 22. Rac1 Bxe4 23. Bxe4 Nc5 24. Bd5 c6 25. Bg2 Qc7 26. d4 exd4 27. exd4 Nd7 28. Re1 c5 29. d5 Ne5 30. Qc3 Qd6 31. f4 Nf7 32. Re6 Qc7 33. Rce1 Nd6 34. Re7 Rd7 35. R7e6 b5 36. cxb5 Nxb5 37. Qc4 Nd6 38. Qa6 c4 39. Qc6 Qa7+ 40. Kh1 Nf5 41. Re8 Rdf7 42. d6 Nd4 43. Qxc4 {Eljanov,P (2678)-Korobov,A (2702) Moscow 2013 1-0}) 14. Rfc1 $146 {[%emt 0:14:41]} (14. Rfd1 Qe8 15. d4 a4 16. Ncd2 exd4 17. b4 Qh5 18. Qd3 Bf5 19. Ne4 Ne5 20. Nxe5 fxe5 21. Rdc1 c6 22. e3 Rd7 23. exd4 exd4 24. Qd2 Qf7 25. Qf4 Be6 26. Qxf7+ Kxf7 27. Bf1 d3 28. Nd2 Rad8 29. f3 Bf6 30. Bxf6 gxf6 31. Kf2 Rd4 32. Rc3 Bc4 33. Re1 Bb5 34. Re4 Rxe4 35. fxe4 Nd7 36. Bxd3 Ne5 37. Bxb5 Rxd2+ 38. Ke3 Rxh2 39. Bxa4 Rg2 40. Kd4 Rd2+ 41. Ke3 Rg2 42. Kd4 Ke7 43. Kc5 Nd7+ {Ponomariov,R (2723)-Vachier Lagrave,M (2710) Beijing 2011 0-1 (90)}) 14... Qe8 {[%emt 0:05:03]} 15. Nxb6 {[%emt 0:04:35]} cxb6 {[%emt 0:00:24]} 16. Nd2 {[%emt 0:00:03]} Rac8 {[%emt 0:04:42]} 17. a4 {[%emt 0:08:55]} Bc5 {[%emt 0:11:35]} 18. Qd1 {[%emt 0:05:08]} h5 {[%emt 0:06:58]} 19. Nc4 {[%emt 0:06:02]} Qe7 {[%emt 0:07:01]} 20. e3 {[%emt 0:11:27]} Bg4 {[%emt 0:03:24]} 21. Qf1 {[%emt 0:00:34]} Nb4 {[%emt 0:08:35]} 22. Rd1 {[%emt 0:00:01]} Bxd1 {[%emt 0:06:35]} 23. Rxd1 {[%emt 0:00:02]} Qf7 {[%emt 0:00:41]} 24. Kh1 {[%emt 0:07:45]} h4 {[%emt 0:05:12]} 25. Qe2 {[%emt 0:10:50]} hxg3 {[%emt 0:15:52]} 26. fxg3 {[%emt 0:00:02]} Bf8 {[%emt 0:02:52]} 27. g4 {[%emt 0:00:44]} b5 {[%emt 0:00:41]} 28. axb5 {[%emt 0:00:17]} a4 {[%emt 0:00:05]} 29. g5 {[%emt 0:02:55]} axb3 {[%emt 0:03:20]} 30. Be4 {[%emt 0:01:50]} Nxd3 {[%emt 0:03:04]} 31. Rxd3 {[%emt 0:00:54]} Qxc4 {[%emt 0:01:24]} 32. Bd4 {[%emt 0:04:16]} b2 {[%emt 0:02:18]} 0-1


