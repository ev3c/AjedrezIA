{[%evp 0,86,19,31,14,-14,27,34,58,60,83,79,85,75,123,71,87,51,37,48,49,56,50,57,101,73,45,-11,27,-23,13,-30,0,-25,-43,-44,-10,-1,-8,-7,0,2,3,-17,-47,-17,-36,0,0,-32,0,-19,-2,0,5,5,24,0,81,24,65,72,66,67,67,65,65,67,67,67,36,41,76,49,59,39,33,33,33,24,24,24,33,60,53,33,53,47,52]} 1. d4 Nf6 2. c4 c5 3. d5 e6 4. Nc3 exd5 5. cxd5 d6 6. Nf3 g6 7. Nd2 Bg7 8. e4 O-O 9. Be2 Na6 10. O-O Nc7 11. a4 a6 $5 (11... b6 {- 120/37}) 12. Kh1 {Diagram [#]} (12. Nc4 b5 $1 13. axb5 (13. Nb6 Rb8 14. Nxc8 Qxc8 $13) 13... axb5 14. Rxa8 Nxa8 15. Nxb5 Nxe4 16. Bf4 Qf6 17. g3 (17. Be3 Bd7 $13) 17... Bh3 18. Nbxd6 (18. Re1 Nxf2 19. Kxf2 g5 20. Bg4 Bxg4 21. Qxg4 gxf4 22. Qxf4 Qxf4+ 23. gxf4 Rb8 24. Nbxd6 Bd4+ 25. Kf3 Nc7 $11) 18... Nxd6 19. Bxd6 Bxf1 20. Bxf1 Nb6 $1 21. Bxf8 Bxf8 22. b3 Nxc4 23. bxc4 h5 $11) 12... Qe7 $6 $146 (12... b6 $1) 13. f4 h5 14. h3 Rd8 $2 {Diagram  [#]} (14... Bd7) 15. Ra3 (15. f5 $1 Rb8 (15... Bd7 16. e5 $1) 16. fxg6 fxg6 17. e5 $1 dxe5 (17... Qxe5 18. Nf3 Qe8 19. Bg5 $18) 18. Nde4 Nxe4 19. Nxe4 $18) 15... Rb8 16. a5 Bd7 17. Rb3 Nb5 $1 18. Bxb5 axb5 19. Nxb5 Bxb5 20. Rxb5 Nxe4 21. Qf3 (21. Nxe4 $142 Qxe4 22. f5 Kh7 23. Rb6 (23. fxg6+ fxg6 24. Re1 (24. Rf7 $2 Rf8 25. Rbxb7 Rxb7 26. Rxb7 Rf2 27. Qg1 Re2 $17) 24... Qf5 $13) 23... Rd7 24. a6 (24. Bf4 Rbd8 $13) 24... Re8 25. axb7 Rb8 26. f6 Bh6 27. Bxh6 Kxh6 $13) 21... Nf6 (21... Qd7 $1 22. Rb6 Nxd2 23. Bxd2 Qf5 $11) 22. Nc4 (22. f5 g5 23. Nc4 g4 24. hxg4 Nxg4 $132) 22... Qe4 23. Qxe4 Nxe4 24. Kh2 h4 $1 25. Be3 Ng3 26. Re1 (26. Rb1 Nf5 27. Bd2 Re8 28. Rb6 Re4 29. Nxd6 (29. b3 Ra8 30. Rxb7 Re2 $11) 29... Nxd6 30. Rxd6 Bh6 31. Rf1 Rd4 32. Bc1 Rc4 33. Bd2 Rd4 $11) 26... Nf5 27. Bf2 Bd4 28. Kg1 (28. Bxd4 cxd4 $13) 28... Re8 29. Kf1 Bxf2 30. Kxf2 Rxe1 31. Kxe1 Re8+ 32. Kd2 Re7 33. Rb6 Rd7 34. Ne3 Nxe3 35. Kxe3 f5 $2 {Diagram [#]} (35... Kg7 36. Kd3 (36. f5 g5 $11) 36... Kf6 37. Kc4 (37. Ke4 g5 $11) 37... Kf5 38. Kb5 Kxf4 39. a6 bxa6+ 40. Kc6 Ra7 41. Kxd6 Kg3 42. Kc6 f5 43. d6 Kxg2 44. d7 Rxd7 45. Kxd7 g5 $11) 36. Kf3 $2 (36. Kd3