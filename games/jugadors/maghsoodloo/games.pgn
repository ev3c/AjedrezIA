{[%evp 13,100,18,21,20,35,24,27,35,40,24,23,32,27,34,38,35,29,29,35,25,26,16,20,13,5,17,12,-1,-1,-52,-31,-31,-31,-57,-44,-16,-38,-81,-77,-93,-117,-106,-102,-117,-125,-115,-117,-159,-118,-167,-124,-196,-193,-202,-174,-195,-177,-182,-194,-190,-187,-129,-208,-190,-189,-159,-181,-173,-183,-190,-194,-189,-165,-533,-507,-636,-640,-582,-610,-567,-567,-567,-567,-567,-557,-567,-567,-567,-567] B62: Sicilian: Richter-Rauzer: 6...e6: Unusual White 7th moves} 1. e4 c5 2. Nf3 Nc6 3. d4 cxd4 4. Nxd4 Nf6 5. Nc3 d6 6. Bg5 e6 7. Bb5 Bd7 8. Qd3 h6 9. Bh4 {*} Be7 $146 (9... Qb6 {- 140/67}) 10. O-O-O {White has an edge.} O-O 11. Bxc6 $1 Bxc6 12. f4 Rc8 13. Rhe1 a6 $146 {Against Ndb5} ({RR} 13... Re8 14. Qh3 Qa5 15. f5 Bd7 16. g4 b5 17. g5 hxg5 18. Bxg5 b4 19. Rg1 Rxc3 20. Qh4 Qe5 21. bxc3 Qxe4 22. Qxe4 Nxe4 23. Bxe7 Rxe7 24. fxe6 fxe6 25. cxb4 Nc3 26. Rde1 e5 27. a3 d5 28. Nf3 {Mottola,M (2247)-Yudasin,L (2290) New York 2025 ½-½ (73)}) ({RR} 13... Qa5 14. f5 e5 15. Nb3 Qb6 16. Bxf6 Bxf6 17. Kb1 Rfd8 18. Nd2 Qc5 19. Nd5 Bg5 20. Nb3 Qf2 21. Re2 Qh4 22. g3 Qh3 23. Nc3 b6 24. Nd2 Rc7 25. Nf3 Be7 26. Ng1 Qh5 27. Rg2 f6 28. g4 {Geher,K (2279)-Feher,G (2336) Hungary 2021 1-0 (63)}) 14. Nxc6 Rxc6 15. e5 $1 Ne8 16. Bxe7 Qxe7 17. Kb1 b5 18. Ne4 d5 19. Ng3 b4 $13 20. Ne2 $146 Nc7 21. Nd4 {[%eval -52,20] Repels Nb5} (21. f5 $11 {[%eval -1,18]}) 21... Rc4 $15 22. f5 Nb5 23. Qg3 Qg5 (23... Nxd4 $2 24. f6 Nf5 25. fxe7 $18) (23... Rfc8 {is interesting.} 24. f6 Qf8 25. Nxb5 axb5 26. Re2 g5) 24. Qxg5 hxg5 25. Nf3 {[%eval -81,21]} (25. Nxb5 $15 {[%eval -38,22] deserves consideration.} axb5 26. Re2) 25... g4 $17 {Black is more active.} 26. Ng5 exf5 27. Rxd5 Re8 $36 {[%mdl 2048] Black is on the roll.} 28. Red1 Rc7 29. Rd8 Rce7 (29... Rc8 30. Rxc8 Rxc8 31. Rd7 $11) 30. a4 {[%eval -159,23]} ({White should play} 30. R1d7 {[%eval -117,22]}) 30... bxa3 31. c4 {[%eval -167,23]} (31. R1d7 $17 {[%eval -118,21] was worth a try.}) 31... Nc7 $19 32. R1d7 {[%eval -196,20] [#]} (32. Rxe8+ $17 {[%eval -124,21]} Rxe8 33. bxa3) 32... Rxd7 $1 (32... Rxe5 33. Nxf7 Re1+ 34. Ka2 axb2 35. Kxb2 Rxd8 36. Nxd8) 33. Rxd7 Ne6 34. Nxe6 Rxe6 {[%mdl 4096] Endgame KR-KR. Black is a pawn up.} 35. c5 axb2 36. Kxb2 Rxe5 37. c6 Rc5 (37... Rb5+ 38. Ka3 Rc5 39. c7 $11) 38. c7 {[#] And now Rd8+ would win.} Kh7 $1 39. Rxf7 Kg6 40. Rd7 Kf6 41. g3 g5 42. Kb3 a5 43. Ka4 $2 {[%eval -533,22]} (43. Rd6+ {[%eval -165,20] nothing else works.} Ke5 44. Rd7) 43... f4 {Black is clearly winning.} 44. gxf4 gxf4 45. Rd6+ Ke5 46. Rd7 f3 47. Rg7 Kf4 {Prevents Rg5.} 48. Rf7+ Ke3 49. Re7+ Kf2 {...Kg2 would now be deadly.} 50. Rg7 {Weighted Error Value: White=0.22 (precise) /Black=0.02 (flawless)} Ke2 0-1


