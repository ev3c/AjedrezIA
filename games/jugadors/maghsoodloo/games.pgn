{[%evp 0,63,21,10,79,83,73,75,75,42,53,53,87,61,61,64,64,68,62,54,54,43,20,16,49,51,67,46,39,39,40,39,39,42,42,42,53,79,79,79,79,79,79,83,83,40,106,9,9,35,263,288,275,254,432,432,1276,1302,1302,1404,1454,1470,1470,1513,1554,1570]} 1. e4 {Prusikin,Michael} g6 2. d4 Bg7 3. Nc3 d6 4. f4 a6 ({RR} 4... Nf6) 5. Nf3 b5 6. Bd3 Nd7 7. e5 Bb7 (7... c5 8. Be4 Rb8 9. O-O cxd4 ({RR} 9... b4) 10. Nxd4 dxe5 ({RR} 10... Bb7 11. Bxb7 Rxb7 12. e6) 11. Nc6 $14) ({RR} 7... c5 8. Be4 Rb8 9. O-O cxd4 10. Nxd4 dxe5 11. Nc6 Qb6+ 12. Kh1 Ngf6 13. Nxb8 Qxb8 14. fxe5 Nxe5 15. Bf4) 8. O-O c5 9. Ng5 (9. Be4 $5) ({RR} 9. Be4) 9... Qb6 (9... h6 $2 10. Nxf7 Kxf7 11. Qg4 {[%cal Rd3g6,Rg4e6]} e6 (11... Nf8 12. e6+) 12. Qxg6+ Kf8 13. f5) (9... cxd4 10. e6 f5 11. exd7+ Qxd7 12. Ne2 $14 h6 13. Nf3 e5) ({RR} 9... Nh6 10. f5 cxd4 ({RR} 10... dxe5 11. fxg6 hxg6 12. Rxf7 Nxf7 13. Bxg6 cxd4 14. Bxf7+ Kf8 15. Bd5 ({RR} 15. Ne6+ Kxf7 16. Nxd8+ Raxd8 17. Ne2 Bf6) 15... Bxd5 16. Nxd5 Nc5 17. Qf3+ Bf6 18. Nxf6 exf6 19. b4 Kg7 20. Qg3 fxg5 21. Bxg5 Ne4 22. Qxe5+ Nf6 23. Rf1 Rf8 24. Qg3) 11. fxg6 dxc3 12. gxf7+ Nxf7 13. Nxf7 Qb6+ 14. Kh1 Qc6 15. Qg4 O-O 16. Bxh7+ Kxh7 17. Ng5+ Kg8 18. Qe6+ Rf7 19. Qxf7+) 10. Be4 (10. e6 $2 Bxd4+ 11. Kh1 fxe6) 10... Bxe4 11. Ncxe4 d5 (11... Nh6 $5) (11... cxd4 $2 12. e6) 12. Nc3 ({RR} 12. dxc5 Qc6 ({RR} 12... Nxc5 13. Be3 dxe4 14. Qd5) 13. Nf2 Nxc5 14. Be3 Nh6 15. Nd3 Nxd3 16. cxd3 O-O 17. Rc1 Qd7 18. Bc5 Rfc8 19. Qe2 Rc6 20. d4 f6 21. Nf3 Rac8 22. Rc3 Nf5 23. Ne1 b4 24. Rh3 a5 25. Nd3 h5 26. b3 Qe6) 12... e6 13. Be3 cxd4 14. Bxd4 Qc6 15. a4 b4 ({RR} 15... bxa4 16. Nxa4 Ne7 17. Nf3) 16. Nb5 $1 {[%csl Gd6][%cal Gb5d6]} axb5 17. axb5 Qb7 (17... Rxa1 18. bxc6 Rxd1 19. cxd7+ Kxd7 20. Rxd1 Ne7 21. g3 Ke8 $2 (21... Ra8 $1 22. Nxf7 $14) 22. Ra1) 18. Rxa8+ Qxa8 19. f5 $1 Nxe5 (19... gxf5 20. Qh5 Nh6 21. Nxe6 {Threatening Nc7} Bxe5 22. Bxe5 Nxe5 23. Nc7+) (19... exf5 20. e6 Bxd4+ 21. Qxd4 f6 22. exd7+ Kxd7 23. Nf7) (19... Bxe5 20. fxe6 fxe6 21. Nf7 $18) ({RR} 19... gxf5 20. Qh5) ({RR} 19... exf5 20. e6) ({RR} 19... Bxe5 20. fxe6 fxe6 21. Nf7) 20. fxe6 f6 (20... fxe6 21. Nxe6 Qb7 22. Nxg7+ Qxg7 23. Re1) 21. Bxe5 fxe5 22. Rf7 Bf8 23. Nxh7 (23. Qf1 $1 Bc5+ (23... Nh6 24. b6 Qc6 25. Nxh7 Be7 26. Rxe7+ Kxe7 27. Qf6+ Kd6 28. e7+ Kc5 29. Qxh8) 24. Kh1 Ne7 25. b6 Qc6 26. Qf6 Rg8 27. Rxe7+ Bxe7 28. Qf7+ Kd8 29. Qxg8+) ({RR} 23. Qf1 Bc5+ 24. Kh1 Ne7 25. b6 Qc6 26. Qf6 Rg8 27. Rxe7+ Bxe7 28. Qf7+ Kd8 29. Qxg8+ Qe8 30. Nf7+) 23... Bc5+ 24. Kh1 Ne7 (24... Be7 25. b6 Kd8 (25... Nh6 26. Nf6+ Bxf6 27. b7 Qb8 28. Qxd5) ({RR} 25... Nh6 26. Nf6+ Bxf6 27. b7 Qb8 28. Qxd5 Nxf7 29. Qd7+ Kf8 30. Qxf7#) 26. Qf1 Nh6 27. Qb5 Qb7 28. Rf1 Rxh7 29. Ra1 {Great idea !!} Bf8 30. Ra7 Nf5 31. Rxb7 Rxb7 32. Qxd5+ Nd6 33. Qc5 $18) ({RR} 24... Be7 25. b6 Kd8 26. Qf1 Nh6 27. Qb5 Qb7 28. Rf1 Rxh7 29. Ra1 Bf8 30. Ra7 Nf5 31. Rxb7 Rxb7 32. Qxd5+ Nd6 33. Qc5) 25. Qf1 Nf5 26. b6 Qc6 (26... Nd6 27. Rf8+ Rxf8 28. Qxf8#) 27. b7 Ba7 28. Qxf5 gxf5 29. Nf6+ Kd8 30. e7+ {resign} Kc7 $146 31. e8=Q+ Kb6 32. Qxh8 1-0


