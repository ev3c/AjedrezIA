[White "Maghsoodloo, Parham"]
[Black "Guseinov, Gadir"]
[Result "1-0"]
[Annotator "Flear,Glenn, TA*"]
[ECO "E91"]
[WhiteElo "2676"]
[BlackElo "2665"]
[PlyCount "95"]
