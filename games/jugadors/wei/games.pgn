:00:06]} Kg6 {[%emt 0:00:08]} 38. Nh4+ {[%emt 0:02:25]} Kg7 {[%emt 0:00:02]} 39. Rf5 {[%emt 0:00:20]} Ne7 {[%emt 0:04:11]} 40. Re5 {[%emt 0:00:00]} f6 {[%emt 0:00:56]} 41. Rxe7+ {[%emt 0:23:02]} Rxe7 {[%emt 0:00:10]} 42. Nf5+ {[%emt 0:00:02]} Kf8 {[%emt 0:00:05]} 43. Nxe7 {[%emt 0:00:04]} Kxe7 {[%emt 0:00:03]} 44. Kf4 {[%emt 0:00:06]} Ke6 {[%emt 0:00:05]} 45. a4 {[%emt 0:00:12]} b6 {[%emt 0:03:04]} 46. b3 {[%emt 0:00:52]} c6 {[%emt 0:00:10]} 47. b4 {[%emt 0:04:05]} a5 {[%emt 0:00:25]} 48. Kf3 {[%emt 0:01:20]} Kd6 {[%emt 0:01:22]} 49. bxa5 {[%emt 0:00:16]} bxa5 {[%emt 0:00:07]} 50. Kg3 {[%emt 0:00:35]} Ke7 {[%emt 0:00:06]} 51. Kf4 {[%emt 0:00:43]} Ke6 {[%emt 0:00:05]} 52. Kf3 {[%emt 0:00:32]} Ke7 {[%emt 0:01:02]} 53. Kf4 {[%emt 0:00:37]} Ke6 {[%emt 0:00:07]} 54. Ke3 {[%emt 0:00:19]} Kf7 {[%emt 0:00:13]} 55. Kf3 {[%emt 0:00:04]} Ke7 {[%emt 0:00:05]} 1/2-1/2


