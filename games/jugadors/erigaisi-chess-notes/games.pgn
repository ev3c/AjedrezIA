{[%evp 0,59,42,12,100,79,100,36,32,-2,-16,-31,-12,6,-5,-5,67,10,65,-14,23,32,
31,52,52,56,56,64,133,92,106,69,77,69,108,97,106,102,98,102,140,120,128,116,
163,115,125,127,103,108,113,108,108,98,109,90,90,84,84,86,95,105]} 1. d4 {
Erigaisi, Arjun} d5 2. Nf3 Nf6 {This came as a surprise so I decided to
counter surprise him over the board with this calm move.} 3. Bf4 Bf5 4. e3 {
White aims to develop quickly on the kingside instead of going for the central
break.} e6 {With this move Black decides to accept IQP and tries to look for
activity} 5. Bd3 Bg6 6. Ne5 Bxd3 7. cxd3 Nbd7 8. Qb3 (8. Nc3 Nxe5 9. dxe5 {
[%cal Gb3b4,Gb2b4] is the most precise} Nd7 10. h4 h5 {would have been the
simplest if it weren't for} 11. d4 Be7 12. Qe2 c6 13. O-O-O {after which
White's bishop is stranded and it's tough to roll the pawns although this
still should be won with some struggle.} {White should not rush with} a5 $2 {
as after} 14. Kb1 {he loses the pawn on a3.}) 8... Rb8 9. Nc3 {Preventing all
kinds of Ng4/Bg4 business before playing Be3.} Nh5 10. Nxd7 Qxd7 $6 11. Be5 f6
{Qc8 with a double attack is the threat for now.} 12. Bg3 $14 {This is already
a slight edge for White as the bishop on d4 looks like a monster.} Be7 13. e4 {
Unfortunate that he touched the bishop intending Bb4 which runs into Bxg7.}
Nxg3 {This was the best move available for him after touching the bishop, but
this is already close to lost as Black is losing a pawn by force and it's
psychologically very tough for him to continue and offer most resistance as he
ended up in such a horrendous position in just 13 moves!} 14. hxg3 c6 15. O-O-O
b5 16. Kb1 a5 17. g4 O-O 18. f4 a4 19. Qc2 {White's aim is to win the a7 pawn
and create outside passers on the queenside.} Qa7 {Black intends to get the
pawn to a4 and restrict White's b2 pawn.} 20. Ne2 Rfc8 21. f5 $1 {Putting
pressure on the target.} exf5 22. gxf5 {Trying to trade off Black's active
rook after which the pawn on a4 would be extremely weak.} b4 23. Qd2 b3 24. a3
c5 25. Nf4 dxe4 {White finally achieved what he wanted and now it's a matter
of technique.} 26. Qe2 cxd4 $6 {Doesn't change the result of the game but it
is a dubious move because it makes White's job easier.} 27. Qxe4 $1 Qd7 28. Ng6
hxg6 29. fxg6 f5 30. Qe2 {Black resigned here although White still needs to
show some precision.} {He could have tried to offer better resistance with} Bg5
31. Rh7 {wins too:} Bh6 32. Rh1 Qc6 33. Qe1 Qc2+ 34. Ka1 $18 Qc1+ {would have
offered more resistance as now Rb5 can be met with} 1-0


