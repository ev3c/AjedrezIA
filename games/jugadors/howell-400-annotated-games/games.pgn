1. e4 d6 2. d4 Nf6 3. Nc3 Nbd7 4. g3 {[%draw arrow,h2,h3,green] [%draw arrow,g3,g4,green] [%draw arrow,b7,b5,green] [%draw arrow,c7,c6,green]} (4. g4 h6 5. h3 {[%draw arrow,g1,e2,green]} (5. Nge2 Nxg4) (5. Be3 e5 {[%draw arrow,c5,f4,green]} 6. h3 {[%draw arrow,b7,b5,green]} b5 (6... c6 {[%draw full,c6,green]} 7. Bg2 b5 8. a3 {[%draw arrow,b5,b4,green]} Be7 {[%draw arrow,d7,f8,green] [%draw arrow,f8,g6,green] [%draw arrow,g6,h4,green] [%draw full,g4]} (8... exd4 9. Bxd4 Ne5 {[%draw arrow,e5,g6,green] [%draw arrow,f8,e7,green] [%draw arrow,d7,f8,green] [%draw arrow,f8,g6,green]} 10. f4 Ng6 11. e5 dxe5 12. Bxc6+ Bd7 13. Bxa8 (13. Bxd7+ Nxd7 14. fxe5 Be7) 13... Qxa8 (13... exd4)) 9. Nge2 Nf8 {[%draw arrow,f8,g6,green] [%draw arrow,g6,h4,green] [%draw full,h4,green]}) 7. Bxb5) 5... e5 6. Nge2 {[%draw arrow,b7,b5,green]} (6. Bg2 {[%draw arrow,f1,g2,green]} c6 {[%draw arrow,b7,b5,green]} 7. a4 Be7 8. Nge2 O-O 9. O-O Nh7) 6... Be7 {[%draw arrow,c7,c6,green]} (6... b5 {[%draw arrow,b7,b5,green]}) 7. Be3 {[%draw arrow,b7,b5,green]} c6 8. a4 {[%draw full,a4,green]} Nf8 {[%draw arrow,f8,g6,green] [%draw arrow,g6,h4,green]} (8... O-O 9. Bg2 exd4 {[%draw full,d4,green]} (9... Re8 10. O-O Nf8 {[%draw arrow,f6,h7,green]} 11. f4 exf4 12. Nxf4 N6h7 {[%draw arrow,f8,e6,green] [%draw arrow,e6,g5,green] [%draw full,g5,green] [%draw full,h4,green]}) 10. Bxd4 Ne5 11. f4 Ng6 {[%draw arrow,g6,h4,green] [%draw full,h4,green]} 12. O-O Nh4) 9. Ng3 Ng6 10. Nf5 Bxf5 11. gxf5 Nh4 {[%draw full,h4,green]} 12. Qe2 {[%draw arrow,e1,b1,green]} Nh7 (12... d5 13. O-O-O)) 4... e5 5. Nge2 c6 6. Bg2 (6. a4 Be7 7. Bg2 b6 {[%draw full,b6,green] [%draw arrow,a7,a6,green] [%draw arrow,c8,b7,green] [%draw arrow,b6,b5,green]} 8. O-O a6 9. h3 h5 {[%draw arrow,h5,h4,green] [%draw arrow,g3,g4,green]} 10. Be3 Bb7 {[%draw arrow,b6,b5,green]}) 6... b5 7. a3 Be7 8. O-O O-O 9. h3 a5 10. g4 Ba6 {[%draw arrow,d6,d5,green]} 1-0


